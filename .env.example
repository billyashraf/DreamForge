# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/dreameforge?retryWrites=true&w=majority

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-at-least-32-characters-long

# Google OAuth — create credentials at https://console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# Authorised redirect URIs:
#   http://localhost:3000/api/auth/google/callback   (local dev)
#   https://your-vercel-domain.vercel.app/api/auth/google/callback  (production)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub token (optional) — increases commit-log API rate limit from 60 to 5000 req/h
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=ghp_your_token_here
