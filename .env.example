# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/dreameforge?retryWrites=true&w=majority
# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-at-least-32-characters-long

# Google OAuth — create credentials at https://console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# Authorised redirect URI: http://localhost:3000/api/auth/google/callback (dev)
#                          https://your-domain.com/api/auth/google/callback (prod)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email / SMTP (used for account verification & password resets)
# Example with Gmail: enable App Passwords at myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false  SMTP_USER=you@gmail.com  SMTP_PASS=app-password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password

# Public URL used in email links (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for the cleanup-unverified cron endpoint — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Call DELETE /api/auth/cleanup-unverified with header x-cleanup-secret: <value> from a daily cron job
CLEANUP_SECRET=your-cleanup-secret-at-least-32-characters-long

NODE_ENV=development
